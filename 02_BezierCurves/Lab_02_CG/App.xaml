<Application x:Class="Lab_02_CG.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Lab_02_CG"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ViewModel="clr-namespace:Lab_02_CG.MVVM.ViewModels"
             xmlns:view="clr-namespace:Lab_02_CG.MVVM.Views"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark"/>
                <ui:ControlsDictionary />
                <ResourceDictionary Source="/Resources/Transitions.xaml"/>
                <ResourceDictionary Source="/Resources/DataGrid.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <DataTemplate DataType="{x:Type ViewModel:EditorViewModel}">
                <view:EditorView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type ViewModel:ExperimentsViewModel}">
                <view:ExperimentsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
