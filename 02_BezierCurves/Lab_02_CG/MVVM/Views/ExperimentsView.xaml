<UserControl
        Style="{StaticResource PageTransitionStyle}"
    x:Class="Lab_02_CG.MVVM.Views.ExperimentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Lab_02_CG.MVVM.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:Height="800"
    d:Width="1520"
    mc:Ignorable="d">
    <Grid Margin="20,10,20,20" ColumnDefinitions="2*,*">
        <Grid RowDefinitions="*,*">
            <Grid ColumnDefinitions="*,*">
                <ui:Card
                    Margin="0,0,2.5,2.5"
                    Padding="16,4"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <Grid RowDefinitions="auto,auto,*,auto">
                        <ui:TextBlock
                            HorizontalAlignment="Center"
                            FontTypography="Subtitle"
                            Text="Experiment 1" />
                        <ui:TextBlock
                            Grid.Row="1"
                            Margin="0,0,0,4"
                            HorizontalAlignment="Center"
                            FontTypography="Body"
                            Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            Text="~ The Performance Comparison ~" />
                        <ui:Card
                            Grid.Row="2"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                            <Grid RowDefinitions="auto, auto, auto, *">
                                <StackPanel Orientation="Horizontal">
                                    <ui:TextBlock Text="Points Count: 3" />
                                    <ui:TextBlock Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text=" (constant)" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Row="1"
                                    Margin="0,8,0,0"
                                    Orientation="Horizontal">
                                    <ui:TextBlock VerticalAlignment="Center" Text="Intervals Count: " />
                                    <ui:TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                        Text="{Binding IntervalsCount}" />
                                </StackPanel>
                                <ui:TextBlock
                                    Grid.Row="2"
                                    Margin="6"
                                    HorizontalAlignment="Center"
                                    Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    Text="~ Results ~" />
                                <Border
                                    Grid.Row="3"
                                    BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8">

                                    <Grid>
                                        <Border
                                            Grid.Row="1"
                                            Background="#2E2E2E"
                                            CornerRadius="8">

                                            <ui:DataGrid
                                                HorizontalContentAlignment="Center"
                                                AutoGenerateColumns="True"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                CanUserAddRows="False"
                                                CanUserReorderColumns="False"
                                                CanUserSortColumns="False"
                                                ColumnWidth="*"
                                                GridLinesVisibility="Horizontal"
                                                HeadersVisibility="Column"
                                                HorizontalGridLinesBrush="#1AFFFFFF"
                                                IsReadOnly="True"
                                                ItemsSource="{Binding Result1Table}"
                                                MinColumnWidth="60"
                                                RowHeight="38"
                                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                SelectionChanged="DataGrid_SelectionChanged" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ui:Card>
                        <ui:Button
                            Grid.Row="3"
                            Margin="0,8"
                            HorizontalAlignment="Center"
                            Appearance="Primary"
                            Command="{Binding StartExperiment1Command}"
                            Content="Start Experiment" />
                    </Grid>
                </ui:Card>
                <ui:Card
                    Grid.Column="1"
                    Margin="2.5,0,2.5,2.5"
                    Padding="16,4"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <Grid RowDefinitions="auto,auto,*,auto">
                        <ui:TextBlock
                            HorizontalAlignment="Center"
                            FontTypography="Subtitle"
                            Text="Experiment 2" />
                        <ui:TextBlock
                            Grid.Row="1"
                            Margin="0,0,0,4"
                            HorizontalAlignment="Center"
                            FontTypography="Body"
                            Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            Text="~ The Stability Comparison ~" />
                        <ui:Card
                            Grid.Row="2"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                            <Grid RowDefinitions="auto, auto, auto, *">
                                <StackPanel Orientation="Horizontal">
                                    <ui:TextBlock VerticalAlignment="Center" Text="Points Count: " />
                                    <ui:TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                        Text="{Binding PointsCount}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Row="1"
                                    Margin="0,4"
                                    Orientation="Horizontal">
                                    <ui:TextBlock Text="Calculated at: t = 1.0" />
                                    <ui:TextBlock Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text=" (constant)" />
                                </StackPanel>
                                <ui:TextBlock
                                    Grid.Row="2"
                                    Margin="6"
                                    HorizontalAlignment="Center"
                                    Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    Text="~ Results ~" />
                                <Border
                                    Grid.Row="3"
                                    BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8">

                                    <Grid>
                                        <Border
                                            Grid.Row="1"
                                            Background="#2E2E2E"
                                            CornerRadius="8">

                                            <ui:DataGrid
                                                HorizontalContentAlignment="Center"
                                                AutoGenerateColumns="True"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                CanUserAddRows="False"
                                                CanUserReorderColumns="False"
                                                CanUserSortColumns="False"
                                                ColumnWidth="auto"
                                                GridLinesVisibility="Horizontal"
                                                HeadersVisibility="Column"
                                                HorizontalGridLinesBrush="#1AFFFFFF"
                                                IsReadOnly="True"
                                                ItemsSource="{Binding Result2Table}"
                                                MinColumnWidth="60"
                                                RowHeight="38"
                                                ScrollViewer.HorizontalScrollBarVisibility="Visible"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                SelectionChanged="DataGrid_SelectionChanged" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ui:Card>
                        <StackPanel
                            Grid.Row="3"
                            Margin="0,8"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            
                            <ui:Button
                                Appearance="Primary"
                                Width="100"
                                Command="{Binding PreviousExperimentStepCommand}"
                                Content="Previous"
                                Icon="{ui:SymbolIcon ArrowLeft24}" />
                            
                            <ui:Button
                                Margin="5,0"
                                Appearance="Primary"
                                Command="{Binding StartExperiment2Command}"
                                Content="Start Experiment" />

                            <ui:Button Width="100" Appearance="Primary" Command="{Binding NextExperimentStepCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Next" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <ui:SymbolIcon Symbol="ArrowRight24" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>

                        </StackPanel>
                    </Grid>
                </ui:Card>
            </Grid>
            <ui:Card
                Grid.Row="1"
                Margin="0,2.5,2.5,2.5"
                Padding="16,4,16,16"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Stretch">
                <Grid RowDefinitions="auto,*">
                    <ui:TextBlock
                        Margin="0,0,0,4"
                        HorizontalAlignment="Center"
                        FontTypography="BodyStrong"
                        Text="~ Performance Analysis ~" />
                    <Grid
                        Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                        <Border
                            BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            BorderThickness="4"
                            CornerRadius="4">
                            <ContentControl Content="{Binding PerformanceCanvas, Mode=OneTime}" />
                        </Border>
                    </Grid>
                </Grid>
            </ui:Card>
        </Grid>
        <Grid Grid.Column="1" RowDefinitions="*, auto">
            <ui:Card
                Margin="2.5,0,0,2.5"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Stretch">
                <Grid VerticalAlignment="Stretch" RowDefinitions="auto, *">
                    <ui:TextBlock
                        Margin="0,0,0,4"
                        HorizontalAlignment="Center"
                        FontTypography="Subtitle"
                        Text="Conclusion" />
                    <ui:Card
                        Grid.Row="1"
                        Padding="16"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Stretch">
                        <ui:TextBlock
                            FontSize="14"
                            Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            Text="      Although noticeably slower than the matrix approach, the parametric method is more stable with a large number of points. It successfully calculates points for 1000-degree curve with minimal precision loss but shortly after crashes due to reaching the limits of double type."
                            TextAlignment="Justify"
                            TextWrapping="Wrap" />
                    </ui:Card>
                </Grid>
            </ui:Card>
            <ui:Card
                Grid.Row="1"
                Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"
                Margin="2.5,2.5,0,2.5"
                Padding="8"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Stretch">
                <Grid Margin="0,0,0,16" RowDefinitions="auto,*">
                    <ui:TextBlock
                        Margin="0,0,0,4"
                        HorizontalAlignment="Center"
                        FontTypography="BodyStrong"
                        Text="~ Stability Analysis ~" />
                    <Grid Grid.Row="1">
                        <Border
                            Width="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"
                            Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            BorderThickness="4"
                            CornerRadius="4">
                            <ContentControl Content="{Binding StabilityCanvas, Mode=OneTime}" />
                        </Border>
                    </Grid>
                </Grid>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>