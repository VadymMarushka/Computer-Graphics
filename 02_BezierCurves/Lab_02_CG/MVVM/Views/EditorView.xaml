<UserControl
    x:Class="Lab_02_CG.MVVM.Views.EditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Lab_02_CG.MVVM.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:Height="800"
    d:Width="1520"
    Style="{StaticResource PageTransitionStyle}"
    mc:Ignorable="d">
    <Grid Margin="20,10,20,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.25*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="1.2*" />
            </Grid.RowDefinitions>
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.25*" />
                </Grid.ColumnDefinitions>
                <ui:Card
                    Margin="0,0,2.5,0"
                    Padding="5"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ui:TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,4"
                            HorizontalAlignment="Center"
                            FontTypography="BodyStrong"
                            Text="Control Points" />

                        <ui:Card
                            Grid.Row="1"
                            Padding="3"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Stretch">

                            <ui:ListView ItemsSource="{Binding ControlPoints}">
                                <ui:ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="4"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">

                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem
                                                        Command="{Binding PlacementTarget.Tag.DeleteSpecificPointCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                        CommandParameter="{Binding}"
                                                        Header="Delete Point">
                                                        <MenuItem.Icon>
                                                            <ui:SymbolIcon Symbol="Delete24" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <Grid Margin="5,-2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="1.25*" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Orientation="Horizontal">
                                                    <ui:TextBlock
                                                        FontSize="13.5"
                                                        FontTypography="Body"
                                                        Text="{Binding Name}" />
                                                    <ui:TextBlock
                                                        FontSize="13"
                                                        FontTypography="Body"
                                                        Text=" - " />
                                                    <ui:TextBlock
                                                        FontSize="13.5"
                                                        FontTypography="Body"
                                                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                        Text="{Binding RoleName}" />
                                                </StackPanel>

                                                <Grid
                                                    Grid.Row="1"
                                                    Margin="2.5"
                                                    ColumnDefinitions="auto,*,auto,*">
                                                    <ui:TextBlock
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        FontTypography="Caption"
                                                        Text="x: " />
                                                    <ui:TextBox
                                                        Grid.Column="1"
                                                        MinWidth="40"
                                                        Padding="0,2"
                                                        VerticalContentAlignment="Center"
                                                        Focusable="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                                                        FontSize="10"
                                                        IsHitTestVisible="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                                                        Style="{StaticResource RoundedErrorTextBox}"
                                                        Text="{Binding X, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=True, ValidatesOnDataErrors=True}" />

                                                    <ui:TextBlock
                                                        Grid.Column="2"
                                                        Margin="5,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontTypography="Caption"
                                                        Text=", y: " />
                                                    <ui:TextBox
                                                        Grid.Column="3"
                                                        MinWidth="40"
                                                        Padding="0,2"
                                                        VerticalContentAlignment="Center"
                                                        Focusable="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                                                        FontSize="10"
                                                        IsHitTestVisible="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                                                        Style="{StaticResource RoundedErrorTextBox}"
                                                        Text="{Binding Y, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=True, ValidatesOnDataErrors=True}" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ui:ListView.ItemTemplate>
                            </ui:ListView>
                        </ui:Card>
                    </Grid>
                </ui:Card>
                <Grid Grid.Column="1" RowDefinitions="* , auto">
                    <ui:Card
                        Padding="5"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Stretch">
                        <Grid RowDefinitions="auto, auto, auto , *">
                            <ui:TextBlock
                                HorizontalAlignment="Center"
                                FontTypography="BodyStrong"
                                Text="Add new control point" />
                            <ui:Card Margin="0,2.5,0,0" Padding="5" Grid.Row="1">
                                    <Grid Margin="0,2.5" ColumnDefinitions="auto, *">
                                        <ui:TextBlock VerticalAlignment="Center" Text=" Enter X:  " />
                                        <ui:TextBox
                                            Grid.Column="2"
                                            Height="30"
                                            Padding="5,2"
                                            VerticalContentAlignment="Center"
                                            FontSize="10"
                                            Style="{StaticResource RoundedErrorTextBox}"
                                            Text="{Binding X_tb, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=True, ValidatesOnDataErrors=True}" />
                                    </Grid>
                                </ui:Card>

                            <ui:Card
                                    Grid.Row="2"
                                    Margin="0.2,5"
                                    Padding="5">
                                <Grid Margin="0,2.5" ColumnDefinitions="auto, *">
                                    <ui:TextBlock VerticalAlignment="Center" Text=" Enter Y:  " />
                                    <ui:TextBox
                                            Grid.Column="2"
                                            Height="30"
                                            Padding="5,2"
                                            VerticalContentAlignment="Center"
                                            FontSize="10"
                                            Style="{StaticResource RoundedErrorTextBox}"
                                            Text="{Binding Y_tb, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=True, ValidatesOnDataErrors=True}" />
                                </Grid>
                            </ui:Card>

                            <ui:Button
                                Grid.Row="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Appearance="Primary"
                                Command="{Binding AddCoordinatesCommand}"
                                Content="Add Point" />
                        </Grid>
                    </ui:Card>

                    <ui:Card
                        Grid.Row="1"
                        Margin="0,2,0,0"
                        Padding="5"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Stretch">
                        <Grid RowDefinitions="auto, *">
                            <ui:TextBlock
                                HorizontalAlignment="Center"
                                FontTypography="BodyStrong"
                                Text="Colors" />
                            <ui:Card
                                Grid.Row="1"
                                Margin="0,2.5,0,0"
                                Padding="5"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch">
                                <Grid ColumnDefinitions="*, *" RowDefinitions="*,*">
                                    <StackPanel>
                                        <ui:TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Text="Lines" />
                                        <Grid ColumnDefinitions="*, auto">
                                            <ComboBox
                                                Height="30"
                                                Margin="2,0,2.5,1"
                                                Padding="5,2.5"
                                                VerticalContentAlignment="Center"
                                                FontSize="12"
                                                ItemsSource="{Binding ColorNames}"
                                                SelectedItem="{Binding Line_CB.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Border
                                                Grid.Column="1"
                                                Width="30"
                                                Height="30"
                                                Margin="5,0"
                                                Background="{Binding Line_CB.Code}"
                                                BorderBrush="Gray"
                                                BorderThickness="1"
                                                CornerRadius="4" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <ui:TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Text="Points" />
                                        <Grid ColumnDefinitions="*, auto">
                                            <ComboBox
                                                Height="30"
                                                Margin="2,0,2.5,1"
                                                Padding="5,2.5"
                                                VerticalContentAlignment="Center"
                                                FontSize="12"
                                                ItemsSource="{Binding ColorNames}"
                                                SelectedItem="{Binding Point_CB.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Border
                                                Grid.Column="1"
                                                Width="30"
                                                Height="30"
                                                Margin="5,0"
                                                Background="{Binding Point_CB.Code}"
                                                BorderBrush="Gray"
                                                BorderThickness="1"
                                                CornerRadius="4" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,4,0,0">
                                        <ui:TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Text="Parametric Bézier" />
                                        <Grid ColumnDefinitions="*, auto">
                                            <ComboBox
                                                Height="30"
                                                Margin="2,0,2.5,1"
                                                Padding="5,2.5"
                                                VerticalContentAlignment="Center"
                                                FontSize="12"
                                                ItemsSource="{Binding ColorNames}"
                                                SelectedItem="{Binding Bezier_Parametric_CB.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Border
                                                Grid.Column="1"
                                                Width="30"
                                                Height="30"
                                                Margin="5,0"
                                                Background="{Binding Bezier_Parametric_CB.Code}"
                                                BorderBrush="Gray"
                                                BorderThickness="1"
                                                CornerRadius="4" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,4,0,0">
                                        <ui:TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Text="Matrix Bézier" />
                                        <Grid ColumnDefinitions="*, auto">
                                            <ComboBox
                                                Height="30"
                                                Margin="2,0,2.5,1"
                                                Padding="5,2.5"
                                                VerticalContentAlignment="Center"
                                                FontSize="12"
                                                ItemsSource="{Binding ColorNames}"
                                                SelectedItem="{Binding Bezier_Matrix_CB.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Border
                                                Grid.Column="1"
                                                Width="30"
                                                Height="30"
                                                Margin="5,0"
                                                Background="{Binding Bezier_Matrix_CB.Code}"
                                                BorderBrush="Gray"
                                                BorderThickness="1"
                                                CornerRadius="4" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </Grid>
                    </ui:Card>
                </Grid>
            </Grid>
            <ui:Card
                Grid.Row="1"
                Margin="0,3,0,0"
                Padding="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Stretch">

                <TabControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Margin="5,0" Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="MathFormula24" />
                                <TextBlock VerticalAlignment="Center" Text=" Parametric" />
                            </StackPanel>
                        </TabItem.Header>

                        <Grid Margin="10" RowDefinitions="auto , *">
                            <ui:Card VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                                <Grid ColumnDefinitions="auto, 2*,* , *, auto">
                                    <ui:TextBlock VerticalAlignment="Center" Text="Enter the intervals count: " />
                                    <ui:TextBox
                                        Grid.Column="1"
                                        Padding="5,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        FontSize="12"
                                        Text="{Binding IntervalsParametric, UpdateSourceTrigger=LostFocus}" />
                                    <ui:Button
                                        Grid.Column="2"
                                        Margin="10,0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Appearance="Primary"
                                        Command="{Binding CalculateParametricCommand}"
                                        Content="Calculate"
                                        Icon="{ui:SymbolIcon Calculator24}" />
                                    <ui:Button
                                        Grid.Column="3"
                                        Margin="0,0,10,0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Appearance="Primary"
                                        Command="{Binding BuildParametricCommand}"
                                        Content="Build"
                                        Icon="{ui:SymbolIcon DataLine24}" />
                                    <ui:Button
                                        Grid.Column="4"
                                        Padding="6,5"
                                        Command="{Binding ToggleParametricCommand}"
                                        FontSize="18"
                                        ToolTip="{Binding ParametricVisibilityBtnToolTip}">
                                        <ui:Button.Style>
                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">

                                                <Setter Property="Appearance" Value="Primary" />
                                                <Setter Property="Icon" Value="{ui:SymbolIcon Eye24}" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsParametricVisible}" Value="False">
                                                        <Setter Property="Appearance" Value="Secondary" />
                                                        <Setter Property="Icon" Value="{ui:SymbolIcon EyeOff24}" />
                                                    </DataTrigger>
                                                </Style.Triggers>

                                            </Style>
                                        </ui:Button.Style>
                                    </ui:Button>
                                </Grid>
                            </ui:Card>
                            <ui:Card
                                Grid.Row="1"
                                Margin="0,10,0,0"
                                Padding="16,8,16,16"
                                VerticalAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                                <Grid RowDefinitions="auto,*">
                                    <ui:TextBlock
                                        HorizontalAlignment="Center"
                                        FontTypography="BodyStrong"
                                        Text="Calculations" />
                                    <Border
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8">

                                        <Grid>
                                            <Border
                                                Grid.Row="1"
                                                Background="#2E2E2E"
                                                CornerRadius="8">

                                                <ui:DataGrid
                                                    AutoGenerateColumns="True"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    CanUserAddRows="False"
                                                    CanUserReorderColumns="False"
                                                    CanUserSortColumns="False"
                                                    ColumnWidth="Auto"
                                                    GridLinesVisibility="Horizontal"
                                                    HeadersVisibility="Column"
                                                    HorizontalGridLinesBrush="#1AFFFFFF"
                                                    IsReadOnly="True"
                                                    ItemsSource="{Binding ParametricTable}"
                                                    MinColumnWidth="60"
                                                    RowHeight="38"
                                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                    SelectionChanged="DataGrid_SelectionChanged" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </ui:Card>

                        </Grid>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Margin="5,0" Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Table24" />
                                <TextBlock VerticalAlignment="Center" Text=" Matrix" />
                            </StackPanel>
                        </TabItem.Header>

                        <Grid Margin="10" RowDefinitions="auto , *">
                            <ui:Card VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                                <Grid ColumnDefinitions="auto, 2*,* , *, auto">
                                    <ui:TextBlock VerticalAlignment="Center" Text="Enter the intervals count: " />
                                    <ui:TextBox
                                        Grid.Column="1"
                                        Padding="5,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        FontSize="12"
                                        Text="{Binding IntervalsMatrix, UpdateSourceTrigger=LostFocus}" />
                                    <ui:Button
                                        Grid.Column="2"
                                        Margin="10,0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Appearance="Primary"
                                        Command="{Binding CalculateMatrixCommand}"
                                        Content="Calculate"
                                        Icon="{ui:SymbolIcon Calculator24}" />
                                    <ui:Button
                                        Grid.Column="3"
                                        Margin="0,0,10,0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Appearance="Primary"
                                        Command="{Binding BuildMatrixCommand}"
                                        Content="Build"
                                        Icon="{ui:SymbolIcon DataLine24}" />
                                    <ui:Button
                                        Grid.Column="4"
                                        Padding="6,5"
                                        Command="{Binding ToggleMatrixCommand}"
                                        FontSize="18"
                                        ToolTip="{Binding MatrixVisibilityBtnToolTip}">
                                        <ui:Button.Style>
                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">

                                                <Setter Property="Appearance" Value="Primary" />
                                                <Setter Property="Icon" Value="{ui:SymbolIcon Eye24}" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMatrixVisible}" Value="False">
                                                        <Setter Property="Appearance" Value="Secondary" />
                                                        <Setter Property="Icon" Value="{ui:SymbolIcon EyeOff24}" />
                                                    </DataTrigger>
                                                </Style.Triggers>

                                            </Style>
                                        </ui:Button.Style>
                                    </ui:Button>
                                </Grid>
                            </ui:Card>
                            <ui:Card
                                Grid.Row="1"
                                Margin="0,10,0,0"
                                Padding="16,8,16,16"
                                VerticalAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                                <Grid ColumnDefinitions="2* , *" RowDefinitions="auto,*">
                                    <ui:TextBlock
                                        HorizontalAlignment="Center"
                                        FontTypography="BodyStrong"
                                        Text="Calculations" />
                                    <Border
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8">

                                        <Grid>
                                            <Border
                                                Grid.Row="1"
                                                Background="#2E2E2E"
                                                CornerRadius="8">

                                                <ui:DataGrid
                                                    AutoGenerateColumns="True"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    CanUserAddRows="False"
                                                    CanUserReorderColumns="False"
                                                    CanUserSortColumns="False"
                                                    ColumnWidth="*"
                                                    GridLinesVisibility="Horizontal"
                                                    HeadersVisibility="Column"
                                                    HorizontalGridLinesBrush="#1AFFFFFF"
                                                    IsReadOnly="True"
                                                    ItemsSource="{Binding MatrixTable}"
                                                    MinColumnWidth="60"
                                                    RowHeight="38"
                                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                    SelectionChanged="DataGrid_SelectionChanged" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <ui:TextBlock
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Center"
                                        FontTypography="BodyStrong"
                                        Text="Matrix Row Values" />
                                    <ui:Card
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="10,10,0,0"
                                        VerticalAlignment="Stretch"
                                        VerticalContentAlignment="Stretch">
                                        <Grid RowDefinitions="auto, auto,*">
                                            <Grid ColumnDefinitions="auto, *, auto">
                                                <ui:TextBlock VerticalAlignment="Center" Text="Enter row:  " />
                                                <ui:TextBox
                                                    Grid.Column="1"
                                                    Padding="5,2"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalContentAlignment="Center"
                                                    FontSize="12"
                                                    Text="{Binding MatrixRow, UpdateSourceTrigger=LostFocus}" />
                                                <ui:Button
                                                    Grid.Column="2"
                                                    Margin="5,0,0,0"
                                                    Padding="6,5"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    Appearance="Primary"
                                                    Command="{Binding SearchRowCommand}"
                                                    FontSize="14"
                                                    Icon="{ui:SymbolIcon Search24}" />
                                            </Grid>
                                            <ui:TextBlock
                                                Grid.Row="1"
                                                Margin="0,8"
                                                HorizontalAlignment="Center"
                                                FontTypography="BodyStrong"
                                                Text="~ Found elements &amp; their values ~" />
                                            <ui:Card
                                                Grid.Row="2"
                                                Padding="2"
                                                VerticalAlignment="Stretch"
                                                VerticalContentAlignment="Stretch">
                                                <ui:ListView ItemsSource="{Binding MatrixRowElements}">
                                                    <ui:ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnDefinitions="auto,auto, *">
                                                                <Border
                                                                    Margin="5,0,0,0"
                                                                    Padding="4,2"
                                                                    Background="#444444"
                                                                    BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                                    BorderThickness="2"
                                                                    CornerRadius="4">
                                                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                                        <ui:TextBlock Text="N[" />
                                                                        <ui:TextBlock Text="{Binding I}" />
                                                                        <ui:TextBlock Text="][" />
                                                                        <ui:TextBlock Text="{Binding J}" />
                                                                        <ui:TextBlock Text="]" />
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border
                                                                    Grid.Column="1"
                                                                    Width="10"
                                                                    Height="5"
                                                                    VerticalAlignment="Center">
                                                                    <ui:TextBlock
                                                                        HorizontalAlignment="Center"
                                                                        Foreground="#444444"
                                                                        Text=" " />
                                                                </Border>
                                                                <Border
                                                                    Grid.Column="2"
                                                                    Margin="0,0,10,0"
                                                                    Padding="4,2"
                                                                    Background="#444444"
                                                                    BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                                    BorderThickness="2"
                                                                    CornerRadius="4">
                                                                    <ui:TextBlock
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Text="{Binding Value}" />
                                                                </Border>

                                                            </Grid>
                                                        </DataTemplate>
                                                    </ui:ListView.ItemTemplate>
                                                </ui:ListView>
                                            </ui:Card>
                                        </Grid>
                                    </ui:Card>
                                </Grid>
                            </ui:Card>

                        </Grid>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Margin="5,0" Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="MathSymbols24" />
                                <TextBlock VerticalAlignment="Center" Text=" Tabulate" />
                            </StackPanel>
                        </TabItem.Header>

                        <Grid Margin="10" RowDefinitions="auto,*">
                            <ui:Card
                                Padding="4"
                                VerticalAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                                <Grid ColumnDefinitions="*,*,*,*,*" RowDefinitions="auto,*">
                                    <ui:TextBlock
                                        Margin="4,4,4,0"
                                        HorizontalAlignment="Center"
                                        Text="Min t" />
                                    <ui:TextBox
                                        Grid.Row="1"
                                        Margin="4"
                                        Padding="5,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        FontSize="12"
                                        Text="{Binding MinT_TB, UpdateSourceTrigger=LostFocus}" />

                                    <ui:TextBlock
                                        Grid.Column="1"
                                        Margin="4,4,4,0"
                                        HorizontalAlignment="Center"
                                        Text="Max t" />
                                    <ui:TextBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="4"
                                        Padding="5,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        FontSize="12"
                                        Text="{Binding MaxT_TB, UpdateSourceTrigger=LostFocus}" />

                                    <ui:TextBlock
                                        Grid.Column="2"
                                        Margin="4,4,4,0"
                                        HorizontalAlignment="Center"
                                        Text="Step Δt" />
                                    <ui:TextBox
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Margin="4"
                                        Padding="5,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        FontSize="12"
                                        Text="{Binding StepT_TB, UpdateSourceTrigger=LostFocus}" />

                                    <ui:TextBlock
                                        Grid.Column="3"
                                        Margin="4,4,4,0"
                                        HorizontalAlignment="Center"
                                        Text="Method" />
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="3"
                                        Margin="4"
                                        Padding="5,5"
                                        HorizontalAlignment="Stretch"
                                        VerticalContentAlignment="Center"
                                        FontSize="12"
                                        SelectedValue="{Binding Method_CB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedValuePath="Content">
                                        <ComboBoxItem Content="Parametric" />
                                        <ComboBoxItem Content="Matrix" />
                                    </ComboBox>

                                    <ui:Button
                                        Grid.Row="1"
                                        Grid.Column="4"
                                        Margin="4"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Appearance="Primary"
                                        Command="{Binding TabulateCommand}"
                                        Content="Tabulate"
                                        Icon="{ui:SymbolIcon Calculator24}" />
                                </Grid>
                            </ui:Card>
                            <ui:Card
                                Grid.Row="1"
                                Margin="0,8,0,0"
                                VerticalAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                                <Grid RowDefinitions="auto, *">
                                    <ui:TextBlock
                                        Margin="0,-8,0,8"
                                        HorizontalAlignment="Center"
                                        FontTypography="BodyStrong"
                                        Text="Tabulation Table" />
                                    <Border
                                        Grid.Row="1"
                                        BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8">

                                        <Grid>
                                            <Border
                                                Grid.Row="1"
                                                Background="#2E2E2E"
                                                CornerRadius="8">

                                                <ui:DataGrid
                                                    AutoGenerateColumns="True"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    CanUserAddRows="False"
                                                    CanUserReorderColumns="False"
                                                    CanUserSortColumns="False"
                                                    ColumnWidth="*"
                                                    GridLinesVisibility="Horizontal"
                                                    HeadersVisibility="Column"
                                                    HorizontalGridLinesBrush="#1AFFFFFF"
                                                    IsReadOnly="True"
                                                    ItemsSource="{Binding TabulationTable}"
                                                    MinColumnWidth="60"
                                                    RowHeight="38"
                                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                    SelectionChanged="DataGrid_SelectionChanged" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </ui:Card>
                        </Grid>
                    </TabItem>
                </TabControl>

            </ui:Card>
        </Grid>
        <Grid
            Grid.Column="1"
            Margin="2.5,0,2.5,0"
            RowDefinitions="*, auto">

            <ui:Card
                Padding="8,8,8,16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Stretch">
                <Grid RowDefinitions="auto,*">
                    <ui:TextBlock
                        Margin="0,0,0,8"
                        HorizontalAlignment="Center"
                        FontTypography="Subtitle"
                        Text="Canvas" />
                    <Grid
                        Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                        <Border
                            Width="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"
                            Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            BorderThickness="4"
                            CornerRadius="4">
                            <ContentControl Content="{Binding Canvas, Mode=OneTime}" Cursor="{Binding Cursor}" />
                        </Border>
                    </Grid>

                </Grid>
            </ui:Card>
            <ui:Card
                Grid.Row="1"
                Margin="0,2,0,0"
                Padding="8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Stretch">
                <StackPanel>
                    <ui:TextBlock
                        Margin="0,2,0,4"
                        HorizontalAlignment="Center"
                        FontTypography="BodyStrong"
                        Text="Toolbox" />
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <ui:Button
                            Width="45"
                            Height="45"
                            Appearance="Primary"
                            Command="{Binding MoveCommand}"
                            Icon="{ui:SymbolIcon ArrowMove24,
                                                 FontSize=24}"
                            ToolTipService.ToolTip="Move through the Canvas" />
                        <ui:Button
                            Width="45"
                            Height="45"
                            Margin="8,0"
                            Appearance="Primary"
                            Command="{Binding AddCommand}"
                            Icon="{ui:SymbolIcon Add24,
                                                 FontSize=24}"
                            ToolTipService.ToolTip="Add new points" />
                        <ui:Button
                            Width="45"
                            Height="45"
                            Appearance="Primary"
                            Command="{Binding DragCommand}"
                            Icon="{ui:SymbolIcon HandLeft24,
                                                 FontSize=24}"
                            ToolTipService.ToolTip="Drag points" />
                        <ui:Button
                            Width="45"
                            Height="45"
                            Margin="8,0"
                            Appearance="Primary"
                            Command="{Binding DeleteCommand}"
                            Icon="{ui:SymbolIcon DismissCircle24,
                                                 FontSize=24}"
                            ToolTipService.ToolTip="Delete point" />
                        <ui:Button
                            Width="45"
                            Height="45"
                            Appearance="Primary"
                            Command="{Binding DeleteAllCommand}"
                            Icon="{ui:SymbolIcon Delete24,
                                                 FontSize=24}"
                            ToolTipService.ToolTip="Delete everything" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>
