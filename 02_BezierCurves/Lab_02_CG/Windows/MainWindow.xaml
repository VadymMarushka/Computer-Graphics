<ui:FluentWindow x:Class="Lab_02_CG.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab_02_CG"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:Lab_02_CG.MVVM.Views"
        mc:Ignorable="d"
        Title="Bézier Curves" Height="855" Width="1520" MinHeight="855" MinWidth="1520">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="{Binding Title}"
            Grid.Row="0"
            FontSize="24"
            MouseDown="TitleBar_MouseDown"/>

        <ui:NavigationView Grid.Row="1" x:Name="RootNavigation"
           PaneDisplayMode="Top">

            <ui:NavigationView.MenuItems>

                <ui:NavigationViewItem Content="Editor"
                   x:Name="EditorItem"
                   Icon="{ui:SymbolIcon Edit24}" 
                   TargetPageType="{x:Type views:EditorView}"
                   Tag="editor"/>
                
                <ui:NavigationViewItem Content="Experiments" 
                   Icon="{ui:SymbolIcon Beaker24}"
                   TargetPageType="{x:Type views:ExperimentsView}"/>
                
            </ui:NavigationView.MenuItems>

        </ui:NavigationView>
        <ui:ContentDialogHost x:Name="RootContentDialogHost" Grid.RowSpan="10" Grid.ColumnSpan="10" />
    </Grid>
</ui:FluentWindow>
