<ui:FluentWindow
    x:Class="Lab_01_CG.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Lab_01_CG"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:Lab_01_CG.Converters"
    Title="MainWindow"
    Width="1200"
    Height="675"
    MinWidth="1200"
    MinHeight="675"
    d:Background="#202020"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <converters:SquareToVertexesStringConverter x:Key="VertexesStringConverter"/>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="Squares &amp; Circles"
            Grid.Row="0"
            FontSize="24" />

        <Grid
            Grid.Row="1"
            Margin="10,0,10,10"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Margin="2.5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <ui:Card
                    Margin="0,0,0,2.5"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch" RowDefinitions="auto, *">
                        <ui:TextBlock
                            Margin="0,0,0,5"
                            FontTypography="Subtitle"
                            Text="Squares &amp; Circles on Canvas" />
                        <ui:Card
                            Grid.Row="1"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                            <ui:ListView Margin="-10" ItemsSource="{Binding Squares}">
                                <ui:ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8">
                                            <Grid ColumnDefinitions="auto,*, auto">
                                                <Border
                                                    Width="40"
                                                    Height="40"
                                                    Margin="5,2.5,10,2.5"
                                                    Background="{Binding OuterCircle.FillColor}"
                                                    BorderBrush="{Binding OuterCircle.OutlineColor}"
                                                    BorderThickness="1.5"
                                                    CornerRadius="100">
                                                    <Border
                                                        Width="27.5"
                                                        Height="27.5"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding FillColor}"
                                                        BorderBrush="{Binding OutlineColor}"
                                                        BorderThickness="1.5">
                                                        <Border
                                                            Width="26"
                                                            Height="26"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding InnerCircle.FillColor}"
                                                            BorderBrush="{Binding InnerCircle.OutlineColor}"
                                                            BorderThickness="1.5"
                                                            CornerRadius="100" />
                                                    </Border>
                                                </Border>

                                                <Grid Grid.Column="1" RowDefinitions="1.5*,*">
                                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                                        <ui:TextBlock
                                                            FontSize="18"
                                                            FontTypography="BodyStrong"
                                                            Text="Shape №" />
                                                        <ui:TextBlock
                                                            FontSize="18"
                                                            FontTypography="BodyStrong"
                                                            Text="{Binding Id}" />
                                                    </StackPanel>
                                                    <StackPanel
                                                        Grid.Row="1"
                                                        Margin="0,0,0,5"
                                                        Orientation="Horizontal">
                                                        <ui:TextBlock FontTypography="Caption" Text="O ( " />
                                                        <ui:TextBlock FontTypography="Caption" Text="{Binding CenterX}" />
                                                        <ui:TextBlock FontTypography="Caption" Text=" ; " />
                                                        <ui:TextBlock FontTypography="Caption" Text="{Binding CenterY}" />
                                                        <ui:TextBlock FontTypography="Caption" Text=" ), a = " />
                                                        <ui:TextBlock FontTypography="Caption" Text="{Binding SideLength}" />
                                                        <ui:TextBlock FontTypography="Caption" Text=", R = " />
                                                        <ui:TextBlock FontTypography="Caption" Text="{Binding OuterCircle.Radius}" />
                                                        <ui:TextBlock FontTypography="Caption" Text=", r = " />
                                                        <ui:TextBlock FontTypography="Caption" Text="{Binding InnerCircle.Radius}" />
                                                        <ui:TextBlock FontTypography="Caption" Text=", V = { " />
                                                        <ui:TextBlock FontTypography="Caption">
                                                            <ui:TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource VertexesStringConverter}">
                                                                    <Binding Path="CenterX"/>
                                                                    <Binding Path="CenterY"/>
                                                                    <Binding Path="SideLength"/>
                                                                    <Binding Path="RotationAngle"/>
                                                                </MultiBinding>
                                                            </ui:TextBlock.Text>
                                                        </ui:TextBlock>
                                                        <ui:TextBlock FontTypography="Caption" Text=" }" />
                                                    </StackPanel>
                                                </Grid>
                                                <ui:Button
                                                    Grid.Column="2"
                                                    Width="40"
                                                    Height="40"
                                                    Margin="10,5"
                                                    VerticalAlignment="Center"
                                                    Appearance="Primary"
                                                    Command="{Binding DataContext.DeleteListItemCommand, RelativeSource={RelativeSource AncestorType=ui:ListView}}"
                                                    CommandParameter="{Binding Id}"
                                                    FontSize="18"
                                                    Icon="{ui:SymbolIcon Delete24}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ui:ListView.ItemTemplate>
                            </ui:ListView>
                        </ui:Card>
                    </Grid>
                </ui:Card>
                <ui:Card
                    Grid.Row="1"
                    Margin="0,2.5,0,0"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Top">
                    <StackPanel>
                        <ui:TextBlock
                            Appearance="Primary"
                            FontTypography="Subtitle"
                            Text="New Square &amp; Circles" />
                        <ui:Card Margin="0,5,0,0">
                            <StackPanel Margin="-2.5">
                                <ui:TextBlock FontTypography="BodyStrong" Text="Square's geometrical parameters: " />
                                <Grid Margin="0,10,0,0" ColumnDefinitions="*,*,*,*">
                                    <ui:TextBox
                                        Margin="0,0,5,0"
                                        HorizontalAlignment="Stretch"
                                        FontSize="11"
                                        PlaceholderText="Enter center's X..."
                                        Text="{Binding CenterX_TB, Mode=TwoWay}" />
                                    <ui:TextBox
                                        Grid.Column="1"
                                        Margin="2.5,0"
                                        HorizontalAlignment="Stretch"
                                        FontSize="11"
                                        PlaceholderText="Enter center's Y..."
                                        Text="{Binding CenterY_TB, Mode=TwoWay}" />
                                    <ui:TextBox
                                        Grid.Column="2"
                                        Margin="5,0,0,0"
                                        HorizontalAlignment="Stretch"
                                        FontSize="11"
                                        PlaceholderText="Enter side length..."
                                        Text="{Binding SideLength_TB, Mode=TwoWay}" />
                                    <ui:TextBox
                                        Grid.Column="3"
                                        Margin="5,0,0,0"
                                        HorizontalAlignment="Stretch"
                                        FontSize="11"
                                        PlaceholderText="Enter angle°..."
                                        Text="{Binding Angle_TB, Mode=TwoWay}" />
                                </Grid>
                            </StackPanel>
                        </ui:Card>
                        <ui:Card Margin="0,10,0,0">
                            <StackPanel Margin="-2.5">
                                <ui:TextBlock FontTypography="BodyStrong" Text="Colors:" />
                                <Grid
                                    Margin="0,2.5,0,0"
                                    ColumnDefinitions="auto, * , auto, *, auto, *, auto"
                                    RowDefinitions="auto,*,*">
                                    <ui:TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="Line " />
                                    <ui:TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="Fill " />

                                    <ui:TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        Text="Square" />
                                    <ui:TextBlock
                                        Grid.Row="0"
                                        Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        Text="InnerCircle" />
                                    <ui:TextBlock
                                        Grid.Row="0"
                                        Grid.Column="5"
                                        HorizontalAlignment="Center"
                                        Text="OuterCircle" />

                                    <Border
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Width="30"
                                        Height="30"
                                        Margin="5,0"
                                        Background="{Binding SquareLine_CB.Code}"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="2.5"
                                        HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding ColorNamesForSquareLine}"
                                        SelectedValue="{Binding SquareLine_CB.Name, Mode=TwoWay}" />

                                    <Border
                                        Grid.Row="2"
                                        Grid.Column="2"
                                        Width="30"
                                        Height="30"
                                        Margin="5,0"
                                        Background="{Binding SquareFill_CB.Code}"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <ComboBox
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="2.5"
                                        HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding ColorNames}"
                                        SelectedValue="{Binding SquareFill_CB.Name, Mode=TwoWay}" />

                                    <Border
                                        Grid.Row="1"
                                        Grid.Column="4"
                                        Width="30"
                                        Height="30"
                                        Margin="5,0"
                                        Background="{Binding InnerLine_CB.Code}"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="3"
                                        Margin="2.5"
                                        HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding ColorNames}"
                                        SelectedValue="{Binding InnerLine_CB.Name, Mode=TwoWay}" />

                                    <Border
                                        Grid.Row="2"
                                        Grid.Column="4"
                                        Width="30"
                                        Height="30"
                                        Margin="5,0"
                                        Background="{Binding InnerFill_CB.Code}"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <ComboBox
                                        Grid.Row="2"
                                        Grid.Column="3"
                                        Margin="2.5"
                                        HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding ColorNames}"
                                        SelectedValue="{Binding InnerFill_CB.Name, Mode=TwoWay}" />

                                    <Border
                                        Grid.Row="1"
                                        Grid.Column="6"
                                        Width="30"
                                        Height="30"
                                        Margin="5,0"
                                        Background="{Binding OuterLine_CB.Code}"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="5"
                                        Margin="2.5"
                                        HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding ColorNames}"
                                        SelectedValue="{Binding OuterLine_CB.Name, Mode=TwoWay}" />

                                    <Border
                                        Grid.Row="2"
                                        Grid.Column="6"
                                        Width="30"
                                        Height="30"
                                        Margin="5,0"
                                        Background="{Binding OuterFill_CB.Code}"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <ComboBox
                                        Grid.Row="2"
                                        Grid.Column="5"
                                        Margin="2.5"
                                        HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding ColorNames}"
                                        SelectedValue="{Binding OuterFill_CB.Name, Mode=TwoWay}" />
                                </Grid>
                            </StackPanel>
                        </ui:Card>
                        <ui:Button
                            Margin="0,12.5,0,-5"
                            HorizontalAlignment="Center"
                            Appearance="Primary"
                            Command="{Binding AddShapeCommand}"
                            Content="Add to Canvas" />
                    </StackPanel>
                </ui:Card>
            </Grid>
            <ui:Card
                Grid.Column="1"
                Margin="2.5,0,2.5,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Stretch">
                <Border
                    Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"
                    HorizontalAlignment="Stretch"
                    BorderBrush="{DynamicResource AccentTextFillColorPrimaryBrush}"
                    BorderThickness="5"
                    CornerRadius="2.5">
                    <ContentControl Content="{Binding Canvas, Mode=OneTime}" />
                </Border>
            </ui:Card>
        </Grid>
    </Grid>
</ui:FluentWindow>
