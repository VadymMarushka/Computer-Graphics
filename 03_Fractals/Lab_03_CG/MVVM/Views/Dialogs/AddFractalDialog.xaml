<ContentDialog
    x:Class="Lab_03_CG.MVVM.Views.Dialogs.AddFractalDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add to Gallery"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind VM.IsSaveEnabled, Mode=OneWay}"
    xmlns:conv="using:Lab_03_CG.Services.Implementaions">
    <ContentDialog.Resources>
        <conv:BytesToImageConverter x:Key="BytesToImageConverter" />
    </ContentDialog.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="12" MinWidth="380" MaxWidth="480" >
        <Border
            CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource AccentAAFillColorDefaultBrush}"
            BorderThickness="3">
            <Image
                x:Name="PreviewImage"
                Source="{x:Bind VM.ImageBytes, Mode=OneWay, Converter={StaticResource BytesToImageConverter}}" />
        </Border>

        <StackPanel Spacing="4">
            <TextBlock FontWeight="SemiBold" Text="Title *" />
            <TextBox
                PlaceholderText="Enter a title for this fractal"
                Text="{x:Bind VM.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock FontWeight="SemiBold" Text="Description" />
            <TextBox
                Height="72"
                PlaceholderText="Optional description…"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Text="{x:Bind VM.Description, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock FontWeight="SemiBold" Text="Parameters" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{x:Bind VM.ParameterSummary, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="8,4"
                                CornerRadius="4"
                                Margin="0,0,0,17"
                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="White"
                                    Text="{Binding}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

    </StackPanel>
    </ScrollViewer>
</ContentDialog>
