<Page
    x:Class="Lab_03_CG.MVVM.Views.GalleryView"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Lab_03_CG.MVVM.ViewModels"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <!-- Empty state -->
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="{x:Bind VM.IsEmpty, Mode=OneWay}">
            <FontIcon
                FontSize="64"
                Opacity="0.25"
                Glyph="&#xEB9F;" />
            <TextBlock
                HorizontalAlignment="Center"
                Opacity="0.5"
                FontSize="18"
                Text="No fractals saved yet." />
            <TextBlock
                HorizontalAlignment="Center"
                Opacity="0.35"
                FontSize="13"
                Text="Export a fractal and click 'Save to Gallery' to add one." />
        </StackPanel>

        <!-- Gallery FlipView -->
        <FlipView
            ItemsSource="{x:Bind VM.Fractals, Mode=OneWay}"
            Margin="0"
            Padding="0"
            Visibility="{x:Bind VM.IsNotEmpty, Mode=OneWay}">

            <!-- Remove the built-in horizontal padding that FlipView reserves
                 for its prev/next arrow buttons. -->
            <FlipView.ItemContainerStyle>
                <Style TargetType="FlipViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin"  Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment"   Value="Stretch" />
                </Style>
            </FlipView.ItemContainerStyle>

            <FlipView.ItemTemplate>
                <DataTemplate x:DataType="vm:FractalCardViewModel">
                    <!--
                        Outer Grid fills the FlipView slot.
                        Column 0 (info): auto-sized, constrained 280..420 px.
                        Column 1 (image): takes remaining space.
                        The image always fills the available height; its width
                        follows naturally from Stretch="Uniform".
                    -->
                    <Grid Margin="48,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- ── LEFT: info panel ─────────────────────────── -->
                        <Grid
                            Grid.Column="0"
                            Margin="0,0,24,0"
                            MaxWidth="420"
                            VerticalAlignment="Stretch">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <!-- type badge -->
                                <RowDefinition Height="Auto" />
                                <!-- title -->
                                <RowDefinition Height="Auto" />
                                <!-- description -->
                                <RowDefinition Height="*"    />
                                <!-- parameters -->
                                <RowDefinition Height="Auto" />
                                <!-- delete button -->
                            </Grid.RowDefinitions>

                            <!-- Type badge -->
                            <Border
                                Grid.Row="0"
                                Margin="0,0,0,10"
                                Padding="10,4"
                                CornerRadius="6"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding FractalType}" />
                            </Border>

                            <!-- Title -->
                            <TextBlock
                                Grid.Row="1"
                                Margin="0,0,0,12"
                                FontSize="26"
                                FontWeight="Bold"
                                TextWrapping="Wrap"
                                Text="{Binding Title}" />

                            <!-- Description -->
                            <Border
                                Grid.Row="2"
                                Margin="0,0,0,16"
                                Padding="14,12"
                                CornerRadius="10"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                <StackPanel Spacing="6">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Opacity="0.6"
                                        Text="DESCRIPTION" />
                                    <TextBlock
                                        FontSize="14"
                                        FontStyle="Italic"
                                        TextWrapping="Wrap"
                                        Text="{Binding Description}" />
                                </StackPanel>
                            </Border>

                            <!-- Parameters grid -->
                            <Border
                                Grid.Row="3"
                                Margin="0,0,0,16"
                                Padding="14,12"
                                CornerRadius="10"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                <StackPanel Spacing="0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Opacity="0.6"
                                        Text="PARAMETERS" />
                                    <ItemsControl ItemsSource="{Binding Parameters}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ParameterRow">
                                                <Grid
                                                    Margin="0,3"
                                                    ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="13"
                                                        Opacity="0.55"
                                                        Text="{Binding Label}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        TextWrapping="Wrap"
                                                        Text="{Binding Value}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Delete button -->
                            <Button
                                Grid.Row="4"
                                Height="44"
                                HorizontalAlignment="Stretch"
                                Background="#C0392B"
                                Command="{Binding ElementName=RootPage, Path=VM.DeleteFractalCommand}"
                                CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Foreground="White" Glyph="&#xE74D;" />
                                    <TextBlock Foreground="White" Text="Delete Entry" />
                                </StackPanel>
                            </Button>

                        </Grid>

                        <!-- ── RIGHT: image ──────────────────────────────── -->

                        <Border
                            Grid.Column="1"
                            CornerRadius="12"
                            BorderBrush="{ThemeResource AccentAAFillColorDefaultBrush}"
                            BorderThickness="2">
                            <Image
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Center"
                                Stretch="Uniform"
                                Source="{Binding ImagePath}" />
                        </Border>

                    </Grid>
                </DataTemplate>
            </FlipView.ItemTemplate>
        </FlipView>

    </Grid>
</Page>
